.PHONY: setup snowflake ingest dbt kafka-up kafka-down pipeline analysis all

# ---------------------------------------------------------------------------
# Setup
# ---------------------------------------------------------------------------
setup:
	pip install -r requirements.txt
	python -m textblob.download_corpora

# ---------------------------------------------------------------------------
# Snowflake
# ---------------------------------------------------------------------------
snowflake:
	python scripts/setup_snowflake.py

# ---------------------------------------------------------------------------
# Ingestion
# ---------------------------------------------------------------------------
ingest:
	python -c "from ingestion.yahoo_finance_ingestion import YahooFinanceIngestion; YahooFinanceIngestion().run_full_ingestion()"

# ---------------------------------------------------------------------------
# dbt
# ---------------------------------------------------------------------------
dbt:
	cd dbt/finance_analytics && dbt deps && dbt run && dbt test

# ---------------------------------------------------------------------------
# Kafka
# ---------------------------------------------------------------------------
kafka-up:
	docker-compose up -d

kafka-down:
	docker-compose down

# ---------------------------------------------------------------------------
# Full Pipeline
# ---------------------------------------------------------------------------
pipeline:
	python scripts/run_full_pipeline.py

# ---------------------------------------------------------------------------
# Analysis
# ---------------------------------------------------------------------------
analysis:
	python analysis/finance_analysis.py

# ---------------------------------------------------------------------------
# All-in-one
# ---------------------------------------------------------------------------
all: setup snowflake ingest dbt analysis

# =============================================================================
# Snowflake Configuration
# =============================================================================
SNOWFLAKE_ACCOUNT=your-snowflake-account
SNOWFLAKE_USER=your-username
SNOWFLAKE_PASSWORD=your-password
SNOWFLAKE_WAREHOUSE=FINANCE_WH
SNOWFLAKE_DATABASE=FINANCE_DB
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_ROLE=ACCOUNTADMIN

# =============================================================================
# Kafka Configuration
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_STOCK_PRICES=stock_prices
KAFKA_TOPIC_NEWS=financial_news
KAFKA_TOPIC_CRYPTO=crypto_prices

# =============================================================================
# Yahoo Finance - Tickers & Pairs
# =============================================================================
YAHOO_STOCK_TICKERS=AAPL,GOOGL,MSFT,AMZN,TSLA
YAHOO_CRYPTO_TICKERS=BTC-USD,ETH-USD,SOL-USD
YAHOO_FOREX_PAIRS=EURUSD=X,GBPUSD=X,JPYUSD=X

# =============================================================================
# Airflow Configuration
# =============================================================================
AIRFLOW_HOME=/path/to/airflow/home
AIRFLOW__CORE__DAGS_FOLDER=/path/to/dags/folder
